# CogNexus 环境配置
# 复制此文件为 .env 并修改配置

# ===== 安全配置（必须修改！）=====

# JWT 密钥（用于用户认证）— 必填，无默认值
# 生成方式: openssl rand -hex 32
JWT_SECRET=

# JWT 过期时间（小时，默认 168 = 7 天）
JWT_EXPIRE_HOURS=168

# API Key 加密密钥 — 必填，无默认值
# 生成方式: openssl rand -hex 32
ENCRYPTION_KEY=

# ===== CORS 配置 =====
# 允许的来源（逗号分隔，默认仅 https://wielding.ai）
CORS_ORIGINS=https://wielding.ai

# ===== 服务配置 =====

# 监听端口
HUB_PORT=8081

# ===== 可选配置 =====

# LLM 全局开关
# LLM_ENABLED=false

# Brave Search API Key（蒙特卡洛模式用）
# BRAVE_API_KEY=
